# AlgoFin Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is NEVER committed to git.
#
# ╔══════════════════════════════════════════════════════════╗
# ║  LOCAL DEVELOPMENT (SQLite — zero infrastructure)        ║
# ║  The values below work out of the box for local dev.     ║
# ║  Only FERNET_KEY and SECRET_KEY should be generated.     ║
# ╚══════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite (no PostgreSQL install needed)
DATABASE_URL=sqlite+aiosqlite:///./algofin_dev.db

# Production (PostgreSQL): uncomment and fill in
# DATABASE_URL=postgresql+asyncpg://algofin:password@localhost:5432/algofin

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: Redis without password (default install)
REDIS_URL=redis://localhost:6379/0

# Production (Redis with password):
# REDIS_URL=redis://:your_password@localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate SECRET_KEY (REQUIRED — at least 32 chars, mandatory in production):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Must be set for production. For local dev, the app falls back to .env value.
# NEVER use the same SECRET_KEY in development and production.

# Generate FERNET_KEY (REQUIRED in production — encrypts exchange API credentials):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The dev.ps1 script auto-generates this for you on first run.
FERNET_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Must match the frontend URL exactly (including port).
ALLOWED_ORIGINS=http://localhost:3000

# ── Environment ───────────────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development

# ── Celery (background task queue) ───────────────────────────────────────────
# Used for scheduled sync jobs (balances, positions, trades).
# For local dev without Celery, these are not required (sync runs on startup).
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Gemini AI (optional — for the AI Assistant feature) ───────────────────────
# Free API key: https://aistudio.google.com/app/apikey
# Leave blank to disable the AI assistant.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Sync schedule (minutes) ───────────────────────────────────────────────────
SYNC_BALANCES_INTERVAL_MINUTES=10
SYNC_POSITIONS_INTERVAL_MINUTES=5
SYNC_TRADES_INTERVAL_MINUTES=20
SYNC_EVENTS_INTERVAL_MINUTES=30

# ── PostgreSQL (only for production Docker Compose) ──────────────────────────
# These are used by docker-compose.yml, not by the app directly.
POSTGRES_DB=algofin
POSTGRES_USER=algofin
POSTGRES_PASSWORD=algofin_dev_password_change_me
REDIS_PASSWORD=algofin_redis_dev_change_me

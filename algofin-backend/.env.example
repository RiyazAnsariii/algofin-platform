# AlgoFin Backend — Environment Variables
# Copy this to .env and fill in real values before running.
# NEVER commit .env to git.

# ── PostgreSQL ───────────────────────────────
POSTGRES_DB=algofin
POSTGRES_USER=algofin
POSTGRES_PASSWORD=algofin_dev_password_change_me

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=algofin_redis_dev_change_me

# ── Application ──────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev_secret_key_change_in_production_must_be_at_least_32_chars

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── JWT ──────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Environment ──────────────────────────────
# development | staging | production
ENVIRONMENT=development

# ── Celery ───────────────────────────────────
CELERY_BROKER_URL=redis://:algofin_redis_dev_change_me@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:algofin_redis_dev_change_me@localhost:6379/2

# ── Gemini AI (free tier) ────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Sync schedule (minutes) ──────────────────
SYNC_BALANCES_INTERVAL_MINUTES=10
SYNC_POSITIONS_INTERVAL_MINUTES=5
SYNC_TRADES_INTERVAL_MINUTES=20
SYNC_EVENTS_INTERVAL_MINUTES=30

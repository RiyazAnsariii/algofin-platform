# AlgoFin Backend — Environment Variables
# ============================================================
# Copy this to .env for local development.
# NEVER commit .env to git.
#
# LOCAL DEVELOPMENT (SQLite — zero infrastructure needed)
# The values below work out of the box for local dev.
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Local dev: SQLite (no PostgreSQL install needed)
DATABASE_URL=sqlite+aiosqlite:///./algofin_dev.db

# Production (Neon free PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/algofin?sslmode=require

# ── Redis ─────────────────────────────────────────────────────
# Local dev: Redis without password
REDIS_URL=redis://localhost:6379/0

# Production (Upstash free Redis):
# REDIS_URL=rediss://:password@region-redis.upstash.io:6379

# ── Security ──────────────────────────────────────────────────
# Generate SECRET_KEY (required — at least 32 chars):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev_secret_key_for_local_demo_only_32chars

# Generate FERNET_KEY (required — encrypts exchange API credentials):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=nDVVCW6_enhSc95mzB6j0OteMIx2c45G6PuygcCf0d0=

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# Production: set to your Vercel URL
# ALLOWED_ORIGINS=https://algofin-platform.vercel.app

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development

# ── Celery (background task queue) ───────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Gemini AI (optional — AI Assistant) ──────────────────────
# Free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# ── Google OAuth (optional — Sign in with Google) ────────────
# Setup: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# ── Sync schedule (minutes) ───────────────────────────────────
SYNC_BALANCES_INTERVAL_MINUTES=10
SYNC_POSITIONS_INTERVAL_MINUTES=5
SYNC_TRADES_INTERVAL_MINUTES=20
SYNC_EVENTS_INTERVAL_MINUTES=30
